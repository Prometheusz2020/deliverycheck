generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Driver {
  id              String     @id @default(uuid())
  name            String     @unique
  password        String     @default("1234")
  totalFeesEarned Float      @default(0)
  deliveries      Delivery[]
  isActive        Boolean    @default(false)
  createdAt       DateTime   @default(now())
}

model Delivery {
  id             String    @id @default(uuid())
  orderNumber    String
  customerName   String?
  address        String?
  totalAmount    Float?
  deliveryFee    Float     @default(0)
  status         String    @default("PENDENTE") // PENDENTE, EM ROTA, ENTREGUE, CANCELADO
  driverId       String?
  driver         Driver?   @relation(fields: [driverId], references: [id])
  deliveryPerson String?   // Nome textual para redundância
  scannedAt      DateTime  @default(now())
  deliveredAt    DateTime?
  paymentMethod  String?
  observations   String?
  itemsCount     Int       @default(1)
  updatedAt      DateTime  @updatedAt
}

model Admin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   @default("123")
  createdAt DateTime @default(now())
}

model Customer {
  id              String       @id @default(uuid())
  name            String       @unique
  phone           String?
  address         String?
  bestPaymentDay  Int?         // Dia do mês (1 a 31)
  creditLimit     Float        @default(0) // 0 significa sem limite
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  sales           CreditSale[]
  payments        Payment[]
}

model CreditSale {
  id              String           @id @default(uuid())
  customerId      String
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  date            DateTime         @default(now())
  totalAmount     Float
  status          String           @default("PENDENTE") // PENDENTE, PAGO
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  gplusId         String?          @unique // ID único do GPlus para evitar duplicidades
  
  items           CreditSaleItem[]
}

model CreditSaleItem {
  id              String     @id @default(uuid())
  saleId          String
  sale            CreditSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  description     String
  quantity        Float      @default(1)
  unitPrice       Float
  totalPrice      Float
}

model Payment {
  id              String   @id @default(uuid())
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  date            DateTime @default(now())
  amount          Float
  paymentMethod   String   @default("DINHEIRO") // PIX, DINHEIRO, DEBITO, CREDITO
  notes           String?
  createdAt       DateTime @default(now())
}
